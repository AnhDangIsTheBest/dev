<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" style="-fx-background-color: #0a0b0f;" xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">

    <VBox alignment="CENTER" maxWidth="360" spacing="24"
          style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 36;">

        <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" text="⚡ Auction76"/>
        <Label style="-fx-font-size: 13; -fx-text-fill: #64748b;" text="Đấu giá bằng cả tính mạng"/>

        <VBox fillWidth="true" spacing="10">
            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Tài khoản"/>
            <TextField fx:id="usernameField" promptText="Username"
                       style="-fx-background-color: #1a1d26; -fx-text-fill: #e2e8f0; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Mật khẩu"/>
            <PasswordField fx:id="passwordField" promptText="Password"
                           style="-fx-background-color: #1a1d26; -fx-text-fill: #e2e8f0; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
        </VBox>

        <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 12;" text="" wrapText="true"/>

        <ProgressIndicator fx:id="loadingIndicator" prefHeight="30" prefWidth="30" visible="false"/>

        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin"
                style="-fx-background-color: #f59e0b; -fx-text-fill: #000; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;"
                text="Đăng nhập"/>

        <Separator style="-fx-background-color: rgba(255,255,255,0.1);"/>

        <Button fx:id="registerButton" maxWidth="Infinity" onAction="#handleRegister"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-padding: 8; -fx-cursor: hand;"
                text="Đăng ký tài khoản mới"/>
    </VBox>
</VBox>
