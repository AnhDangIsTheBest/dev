<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18" style="-fx-background-color: #0a0b0f; -fx-padding: 28;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.DepositController">
    <children>
        <VBox spacing="6">
            <Label text="💳 Nạp tiền" style="-fx-text-fill: #f8fafc; -fx-font-size: 26; -fx-font-weight: bold;" />
            <Label text="Nạp tiền vào ví để tham gia đấu giá." style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" />
        </VBox>

        <VBox spacing="10" style="-fx-background-color: #12141a; -fx-background-radius: 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 14; -fx-padding: 18;">
            <Label text="Số dư hiện tại" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" />
            <Label fx:id="balanceLabel" text="0 đ" style="-fx-text-fill: #f59e0b; -fx-font-size: 30; -fx-font-weight: bold;" />
        </VBox>

        <VBox spacing="10" style="-fx-background-color: #12141a; -fx-background-radius: 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 14; -fx-padding: 18;">
            <Label text="Nhập số tiền muốn nạp" style="-fx-text-fill: #e2e8f0; -fx-font-size: 13; -fx-font-weight: bold;" />
            <TextField fx:id="amountField" promptText="Ví dụ: 1000000" style="-fx-background-color: #1a1d26; -fx-text-fill: #f8fafc; -fx-prompt-text-fill: #64748b; -fx-background-radius: 8; -fx-padding: 10;" />

            <HBox spacing="10">
                <Button fx:id="btnDeposit" onAction="#handleDeposit" text="Nạp tiền" style="-fx-background-color: #f59e0b; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 9 18; -fx-cursor: hand;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="resultLabel" text="" />
            </HBox>
        </VBox>
    </children>
</VBox>
