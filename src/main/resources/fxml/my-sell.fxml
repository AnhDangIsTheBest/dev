<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" style="-fx-background-color: #0a0b0f; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.MySellController">

    <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;" text="💰 Sản phẩm của tôi" />
    <Label fx:id="summaryLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="" />

    <TableView fx:id="itemTable" prefHeight="400.0" prefWidth="842.0" style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.08);" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colItemName" prefWidth="275.0" text="Tên" />
         <TableColumn fx:id="colItemType" prefWidth="85.5" text="Loại" />
         <TableColumn fx:id="colItemPrice" prefWidth="154.0" text="Giá khởi điểm" />
            <TableColumn fx:id="colItemCPrice" prefWidth="165.5" text="Giá hiện tại" />
            <TableColumn fx:id="colItemStatus" prefWidth="158.5" text="Trạng thái" />
        </columns>
        <placeholder><Label style="-fx-text-fill: #64748b;" text="Bạn chưa tham gia phiên nào" /></placeholder>
    </TableView>
</VBox>
