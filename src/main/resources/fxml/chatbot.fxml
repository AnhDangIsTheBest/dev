<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      VBox.vgrow="ALWAYS"
      style="-fx-background-color: transparent; -fx-padding: 12;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.ChatbotController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Trợ lý đấu giá"
                   style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel"
                   text="Ready"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
        </HBox>

        <ScrollPane fx:id="chatScrollPane"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: #0f1117; -fx-background: #0f1117; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 10; -fx-padding: 0;">
            <content>
                <VBox fx:id="messageList"
                      spacing="8"
                      style="-fx-background-color: #0f1117; -fx-padding: 12;"/>
            </content>
        </ScrollPane>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="messageField"
                       onAction="#handleSend"
                       promptText="Nhập tin nhắn..."
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #1a1d26; -fx-text-fill: #f8fafc; -fx-prompt-text-fill: #64748b; -fx-background-radius: 999; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 999; -fx-padding: 10 14;"/>
            <Button fx:id="sendButton"
                    onAction="#handleSend"
                    text="Gửi"
                    style="-fx-background-color: #f59e0b; -fx-text-fill: #111827; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 10 16; -fx-cursor: hand;"/>
        </HBox>
    </children>
</VBox>
