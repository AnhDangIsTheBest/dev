<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.network.client.controller.LoginController"
      alignment="CENTER" spacing="0"
      style="-fx-background-color: #0a0b0f;">

    <VBox alignment="CENTER" spacing="24" maxWidth="360"
          style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 36;">

        <Label text="⚡ AuctionX" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
        <Label text="Hệ thống đấu giá trực tuyến" style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>

        <VBox spacing="10" fillWidth="true">
            <Label text="Tài khoản" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
            <TextField fx:id="usernameField" promptText="bidder1 / seller1 / admin"
                       style="-fx-background-color: #1a1d26; -fx-text-fill: #e2e8f0; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
            <Label text="Mật khẩu" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
            <PasswordField fx:id="passwordField" promptText="123456 / admin123"
                           style="-fx-background-color: #1a1d26; -fx-text-fill: #e2e8f0; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
        </VBox>

        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 12;" wrapText="true"/>

        <ProgressIndicator fx:id="loadingIndicator" prefWidth="30" prefHeight="30" visible="false"/>

        <Button fx:id="loginButton" text="Đăng nhập" onAction="#handleLogin" maxWidth="Infinity"
                style="-fx-background-color: #f59e0b; -fx-text-fill: #000; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Separator style="-fx-background-color: rgba(255,255,255,0.1);"/>

        <Button fx:id="registerButton" text="Đăng ký tài khoản mới" onAction="#handleRegister" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-padding: 8; -fx-cursor: hand;"/>

        <Label text="Demo: bidder1 | seller1 | admin" style="-fx-text-fill: #475569; -fx-font-size: 11;"/>
    </VBox>
</VBox>
