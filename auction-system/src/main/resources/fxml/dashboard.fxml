<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.network.client.controller.AuctionsController"
      spacing="16" style="-fx-background-color: #0a0b0f; -fx-padding: 20;">

    <Label text="Dashboard"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>

    <HBox spacing="12">
        <VBox style="-fx-background-color: #1a1d26; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14;" HBox.hgrow="ALWAYS">
            <Label text="PHIÊN ĐANG CHẠY" style="-fx-text-fill: #64748b; -fx-font-size: 10;"/>
            <Label text="..." style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
        </VBox>
        <VBox style="-fx-background-color: #1a1d26; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14;" HBox.hgrow="ALWAYS">
            <Label text="TỔNG PHIÊN" style="-fx-text-fill: #64748b; -fx-font-size: 10;"/>
            <Label text="..." style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
        </VBox>
        <VBox style="-fx-background-color: #1a1d26; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14;" HBox.hgrow="ALWAYS">
            <Label text="TỔNG BID" style="-fx-text-fill: #64748b; -fx-font-size: 10;"/>
            <Label text="..." style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
        </VBox>
    </HBox>

    <Label text="Danh sách phiên đấu giá (click để xem chi tiết)"
           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
    <Label fx:id="statusLabel" text="" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>

    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.08);">
        <columns>
            <TableColumn fx:id="colName" text="Sản phẩm" prefWidth="220"/>
            <TableColumn fx:id="colCategory" text="Danh mục" prefWidth="100"/>
            <TableColumn fx:id="colPrice" text="Giá hiện tại" prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
            <TableColumn fx:id="colTimer" text="Còn lại" prefWidth="80"/>
            <TableColumn fx:id="colLeader" text="Người dẫn" prefWidth="150"/>
        </columns>
        <placeholder><Label text="Đang tải..." style="-fx-text-fill: #64748b;"/></placeholder>
    </TableView>
</VBox>
