<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.network.client.controller.MyBidsController"
      spacing="14" style="-fx-background-color: #0a0b0f; -fx-padding: 20;">

    <Label text="💰 Giá của tôi"
           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
    <Label fx:id="summaryLabel" text="" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.08);">
        <columns>
            <TableColumn fx:id="colName" text="Sản phẩm" prefWidth="220"/>
            <TableColumn fx:id="colMyBid" text="Giá cao nhất của tôi" prefWidth="160"/>
            <TableColumn fx:id="colCurrent" text="Giá hiện tại" prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
            <TableColumn fx:id="colResult" text="Kết quả" prefWidth="120"/>
        </columns>
        <placeholder><Label text="Bạn chưa tham gia phiên nào" style="-fx-text-fill: #64748b;"/></placeholder>
    </TableView>
</VBox>
