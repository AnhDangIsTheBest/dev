<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.network.client.controller.MainController"
            style="-fx-background-color: #0a0b0f;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #12141a; -fx-border-color: transparent transparent rgba(255,255,255,0.08) transparent; -fx-padding: 0 20; -fx-min-height: 52;">
            <Label text="⚡ AuctionX" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
            <Label text="●" style="-fx-text-fill: #10b981; -fx-font-size: 10;"/>
            <Label text="Live" style="-fx-text-fill: #10b981; -fx-font-size: 11;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userNameLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
            <Label fx:id="userRoleLabel" style="-fx-text-fill: #fbbf24; -fx-font-size: 11; -fx-background-color: rgba(245,158,11,0.15); -fx-padding: 2 8; -fx-background-radius: 10;"/>
            <Button text="Đăng xuất" onAction="#handleLogout"
                    style="-fx-background-color: #1a1d26; -fx-text-fill: #94a3b8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 6; -fx-padding: 5 10; -fx-cursor: hand; -fx-font-size: 12;"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox fx:id="sidebar" spacing="2"
              style="-fx-background-color: #12141a; -fx-border-color: transparent rgba(255,255,255,0.08) transparent transparent; -fx-min-width: 190; -fx-padding: 12 0;">
            <Button fx:id="btnDashboard" text="📊  Dashboard" onAction="#showDashboard"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
            <Button fx:id="btnAuctions" text="🔨  Đấu giá" onAction="#showAuctions"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
            <Button fx:id="btnMyBids" text="💰  Giá của tôi" onAction="#showMyBids"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
            <Button fx:id="btnAutoBid" text="🤖  Auto-Bid" onAction="#showAutoBid"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
            <Button fx:id="btnSeller" text="📦  Sản phẩm" onAction="#showSeller"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
            <Button fx:id="btnAdmin" text="⚙️  Quản trị" onAction="#showAdmin"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
            <Button fx:id="btnHistory" text="📈  Lịch sử" onAction="#showHistory"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-text-alignment: left; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;"/>
        </VBox>
    </left>

    <!-- CONTENT -->
    <center>
        <BorderPane fx:id="mainPane" style="-fx-background-color: #0a0b0f;"/>
    </center>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.08) transparent transparent transparent; -fx-padding: 6 16;">
            <Label fx:id="statusLabel" text="Sẵn sàng." style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
        </HBox>
    </bottom>
</BorderPane>
