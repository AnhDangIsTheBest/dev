<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.SellerController"
            fitToWidth="true"
            style="-fx-background: #0a0b0f; -fx-background-color: #0a0b0f;">
    <VBox spacing="18" style="-fx-background-color: #0a0b0f; -fx-padding: 24 44 36 44;">
        <Label text="ĐĂNG TÀI SẢN MỚI &amp; TẠO CUỘC ĐẤU GIÁ"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
        <Label fx:id="sellerResultLabel" text="" style="-fx-font-size: 12;" wrapText="true"/>

        <HBox spacing="18" alignment="TOP_LEFT">
            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #121416; -fx-border-color: #323941; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 16;">
                <Label text="Chi tiết sản phẩm"
                       style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>

                <Label text="Tên sản phẩm" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                <TextField fx:id="itemNameField" promptText="Ví dụ: Xe ô tô Hyundai Grand i10"
                           style="-fx-background-color: #17191d; -fx-text-fill: #e5e7eb; -fx-prompt-text-fill: #6b7280; -fx-border-color: #343a40; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9;"/>

                <Label text="Loại sản phẩm" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                <ComboBox fx:id="itemTypeCombo" maxWidth="Infinity"
                          promptText="Chọn danh mục"
                          style="-fx-background-color: #17191d; -fx-border-color: #343a40; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Label text="Mô tả sản phẩm" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                <TextArea fx:id="itemDescField" promptText="Mô tả cụ thể về tài sản, thông số kỹ thuật, lịch sử, v.v."
                          prefRowCount="5" wrapText="true"
                          style="-fx-control-inner-background: #17191d; -fx-background-color: #17191d; -fx-text-fill: #e5e7eb; -fx-prompt-text-fill: #6b7280; -fx-border-color: #343a40; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <VBox spacing="8" style="-fx-border-color: #6b7280; -fx-border-style: dashed; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 18;">
                    <ImageView fx:id="selectedImagePreview" fitWidth="180" fitHeight="105" preserveRatio="true" smooth="true"/>
                    <Button text="+ Chọn ảnh sản phẩm" onAction="#handleChooseImage"
                            style="-fx-background-color: #991b1b; -fx-text-fill: white; -fx-font-size: 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Label fx:id="selectedImageLabel" text="Chưa chọn ảnh" wrapText="true"
                           style="-fx-text-fill: #cbd5e1; -fx-font-size: 12;"/>
                </VBox>
            </VBox>

            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #121416; -fx-border-color: #323941; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 16;">
                <Label text="Cài đặt cuộc đấu giá"
                       style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>

                <Label text="Giá khởi điểm" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                <TextField fx:id="itemPriceField" promptText="Ví dụ: 100000000"
                           style="-fx-background-color: #17191d; -fx-text-fill: #e5e7eb; -fx-prompt-text-fill: #6b7280; -fx-border-color: #343a40; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9;"/>

                <GridPane hgap="12" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Ngày bắt đầu" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                    <Label text="Giờ bắt đầu" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                    <DatePicker fx:id="startDatePicker" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <HBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <Spinner fx:id="startHourSpinner" prefWidth="70" editable="true"/>
                        <Label text=":" style="-fx-text-fill: #cbd5e1; -fx-font-size: 16;"/>
                        <Spinner fx:id="startMinSpinner" prefWidth="70" editable="true"/>
                        <Button text="Ngay" onAction="#handleSetStartNow" style="-fx-background-color: #1f2937; -fx-text-fill: #cbd5e1; -fx-background-radius: 6;"/>
                    </HBox>

                    <Label text="Ngày kết thúc" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                    <Label text="Giờ kết thúc" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: #d1d5db; -fx-font-size: 12;"/>
                    <DatePicker fx:id="endDatePicker" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <HBox spacing="6" GridPane.rowIndex="3" GridPane.columnIndex="1">
                        <Spinner fx:id="endHourSpinner" prefWidth="70" editable="true"/>
                        <Label text=":" style="-fx-text-fill: #cbd5e1; -fx-font-size: 16;"/>
                        <Spinner fx:id="endMinSpinner" prefWidth="70" editable="true"/>
                        <Button text="+1h" onAction="#handleAddOneHour" style="-fx-background-color: #1f2937; -fx-text-fill: #cbd5e1; -fx-background-radius: 6;"/>
                    </HBox>
                </GridPane>

                <CheckBox fx:id="antiSnipeCheck" text="Gia hạn thời gian (Anti-Snipe)" selected="true"
                          style="-fx-text-fill: #e5e7eb;"/>
                <Label text="Kích hoạt Anti-Snipe: tự động gia hạn nếu có đấu giá cuối"
                       style="-fx-text-fill: #9ca3af; -fx-font-size: 11;"/>

                <Button text="ĐĂNG SẢN PHẨM &amp; TẠO CUỘC ĐẤU GIÁ" onAction="#handleAddItemAndCreateAuction" maxWidth="Infinity"
                        style="-fx-background-color: #991b1b; -fx-text-fill: #fff; -fx-font-weight: bold; -fx-padding: 13; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </HBox>

        <HBox spacing="18" VBox.vgrow="ALWAYS">
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Sản phẩm của tôi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                <TableView fx:id="itemTable" prefHeight="230" style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.08);">
                    <columns>
                        <TableColumn fx:id="colItemName" text="Tên" prefWidth="190"/>
                        <TableColumn fx:id="colItemCat" text="Loại" prefWidth="100"/>
                        <TableColumn fx:id="colItemPrice" text="Giá KĐ" prefWidth="130"/>
                    </columns>
                    <placeholder><Label text="Chưa có sản phẩm" style="-fx-text-fill: #64748b;"/></placeholder>
                </TableView>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Phiên đấu giá của tôi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                <TableView fx:id="auctionTable" prefHeight="230" style="-fx-background-color: #12141a; -fx-border-color: rgba(255,255,255,0.08);">
                    <columns>
                        <TableColumn fx:id="colAucName" text="Sản phẩm" prefWidth="220"/>
                        <TableColumn fx:id="colAucStatus" text="Trạng thái" prefWidth="110"/>
                        <TableColumn fx:id="colAucPrice" text="Giá hiện tại" prefWidth="130"/>
                    </columns>
                    <placeholder><Label text="Chưa có phiên nào" style="-fx-text-fill: #64748b;"/></placeholder>
                </TableView>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
